# ===========================================
# WisdominDATA Docker 环境变量配置示例
# 复制此文件为 .env 并根据需要修改参数
# ===========================================

# 应用配置
APP_PORT=5000
FLASK_ENV=production

# MySQL数据库配置
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_NAME=evaluation_test_db

# Neo4j图数据库配置
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# Neo4j性能配置
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE_SIZE=512m

# Neo4j插件配置
NEO4J_APOC_EXPORT_ENABLED=true
NEO4J_APOC_IMPORT_ENABLED=true
NEO4J_APOC_USE_CONFIG=true
NEO4J_UNRESTRICTED_PROCEDURES=apoc.*,gds.*
NEO4J_ALLOWED_PROCEDURES=apoc.*,gds.*

# Ollama配置
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_NAMING_MODEL=qwen3:1.7b

# OpenRouter API配置
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-14b
OPENROUTER_API_BASE=https://openrouter.ai/api/v1/

# OpenAI API配置（用于Agent功能）
OPENAI_API_KEY=
OPENAI_API_BASE=https://openrouter.ai/api/v1/

# ChromaDB配置
CHROMA_DB_PATH=/app/chroma_db

# ===========================================
# 离线环境配置说明
# ===========================================
# 1. Neo4j插件已预装在镜像中，无需下载
# 2. Python依赖已打包在镜像中，无需重新安装
# 3. 修改OLLAMA_URL指向离线Ollama服务
# 4. 设置API KEY为空以禁用在线模型服务
# 5. OPENAI_API_KEY可以设置为OPENROUTER_API_KEY的值以复用
# =========================================== 